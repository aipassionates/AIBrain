# Copy this to .env and fill in values. Never commit .env.
# These are the env vars the stack depends on.

# n8n API key — also stored in Windows User env and ~/.claude.json
N8N_API_KEY=

# n8n public URL (already set as Windows Machine env, listed here for reference)
N8N_API_URL=https://api.passionate.agency/api/v1
N8N_HOST=api.passionate.agency
N8N_PROTOCOL=https
WEBHOOK_URL=https://api.passionate.agency/

# Cloudflare tunnel ID (used in DNS CNAME target)
CF_TUNNEL_ID=30618ade-6269-438c-b28a-3fca6b8d297b

# Google Analytics / Search Console (set in PM2 config — no .env needed)
GA4_PROPERTY_ID=321752992
GSC_SITE_URL=https://passionates.com/

# LinkedHelper CDP exe path (set in PM2 config and ~/.claude.json)
LINKEDHELPER_EXE=C:\Users\user\AppData\Local\linked-helper\app-2.113.78\linked-helper.exe

# Future: sales automation stack
RETELL_API_KEY=
SENDGRID_API_KEY=
HUBSPOT_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TELNYX_API_KEY=
